# MAIN
# ══════════════════════════════════════════════════════════════════════════════

def main():
    args = sys.argv[1:]

    if not args or args[0] in ("--help", "-h", "?", "--?"):
        print(HELP); return
    if args[0] == "--add":  cmd_add(args[1:]); return
    if args[0] == "--list": cmd_list(); return

    # parse --render
    render_mode = "auto"
    if "--render" in args:
        idx = args.index("--render")
        if idx + 1 >= len(args): err("--render nécessite : auto|pixel|emoji|ascii"); sys.exit(1)
        render_mode = args[idx+1]; args = args[:idx] + args[idx+2:]

    # parse --bw
    bw = "--bw" in args
    if bw: args = [a for a in args if a != "--bw"]

    if not args: print(HELP); return

    query = " ".join(args)
    bw_label = f" {Y}[bw]{W}" if bw else ""
    print(f"\n{B}🔍 Recherche :{W} {query}  {C}[{render_mode}]{W}{bw_label}\n")

    path = find_image(query)
    if not path:
        err(f"Aucun mème trouvé pour '{query}'.")
        info("Essayez un terme en anglais ou plus court."); sys.exit(1)

    print()
    renderers = {"auto": render_auto, "pixel": render_pixel,
                 "emoji": render_emoji, "ascii": render_ascii}
    if render_mode not in renderers:
        err(f"Mode inconnu : '{render_mode}'. Choix : auto · pixel · emoji · ascii"); sys.exit(1)
    renderers[render_mode](path, bw=bw)
    print(f"\n{G}📁 {path}{W}\n")

if __name__ == "__main__":
    main()
