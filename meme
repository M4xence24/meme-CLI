def cmd_add(args):
    if len(args) < 2: err("Usage : meme --add <nom> <url>"); sys.exit(1)
    name = " ".join(args[:-1]).lower(); src = args[-1]
    db = load_db(); db[name] = src; save_db(db)
    ok(f"'{name}' ajouté à la base locale.")

def cmd_list():
    db = load_db()
    if not db: info("Base locale vide. Utilisez --add pour ajouter des mèmes."); return
    print(f"\n{B}Base locale ({len(db)} mèmes) :{W}")
    for k in sorted(db): print(f"  {DIM}•{W} {k}")
    print()

