def load_db():
    if not os.path.exists(LOCAL_DB): return {}
    with open(LOCAL_DB) as f: return json.load(f)

def save_db(db):
    with open(LOCAL_DB,"w") as f: json.dump(db, f, indent=2, ensure_ascii=False)

def fuzzy_local(query, db):
    if not db: return None
    keys = list(db.keys()); q = query.lower()
    if q in keys: return (q, 1.0)
    m = difflib.get_close_matches(q, keys, n=1, cutoff=FUZZY_CUTOFF)
    if m: return (m[0], difflib.SequenceMatcher(None, q, m[0]).ratio())
    qw = set(q.split()); best_k, best_s = None, 0.0
    for k in keys:
        common = qw & set(k.split())
        if common:
            s = len(common) / max(len(qw), len(k.split()))
            if s > best_s: best_s, best_k = s, k
    return (best_k, best_s) if best_k and best_s >= 0.4 else None

def search_ddg(query):
    try:
        q = urllib.parse.quote_plus(query + " meme")
        html = http_get(f"https://duckduckgo.com/?q={q}&iax=images&ia=images")
        vqd = None
        for pat in [r'vqd=(["\'])?([\d-]+)', r'"vqd"\s*:\s*"([\d-]+)"', r"vqd=([\d-]+)&"]:
            m = re.search(pat, html)
            if m: vqd = m.group(m.lastindex); break
        if not vqd: return None
        h = dict(HEADERS); h["Referer"] = "https://duckduckgo.com/"
        req = urllib.request.Request(
            f"https://duckduckgo.com/i.js?q={q}&o=json&vqd={urllib.parse.quote(vqd)}&f=,,,,,&p=1",
            headers=h)
        with urllib.request.urlopen(req, timeout=10) as r: data = json.loads(r.read())
        for item in data.get("results",[])[:10]:
            u = item.get("image","")
            if u and re.search(r'\.(jpg|jpeg|png|gif|webp)(\?|$)', u, re.I): return u
        res = data.get("results",[])
        return res[0].get("image") if res else None
    except Exception as e: warn(f"DuckDuckGo : {e}"); return None

def search_reddit(query):
    q = urllib.parse.quote_plus(query)
    for sub in ["memes","dankmemes","AdviceAnimals","me_irl"]:
        try:
            req = urllib.request.Request(
                f"https://www.reddit.com/r/{sub}/search.json?q={q}&restrict_sr=1&sort=top&limit=5",
                headers={"User-Agent":"meme-cli/1.0"})
            with urllib.request.urlopen(req, timeout=8) as r: data = json.loads(r.read())
            for post in data.get("data",{}).get("children",[]):
                pd = post.get("data",{})
                u = pd.get("url","")
                if re.search(r'\.(jpg|jpeg|png|gif)$', u, re.I): return u
                imgs = pd.get("preview",{}).get("images",[])
                if imgs:
                    src = imgs[0].get("source",{}).get("url","")
                    if src: return src.replace("&amp;","&")
        except: continue
    return None

def search_kym(query):
    try:
        html = http_get(f"https://knowyourmeme.com/search?q={urllib.parse.quote_plus(query)}")
        m = re.search(r'href="(/memes/[a-z0-9-]+)"', html)
        if not m: return None
        html2 = http_get("https://knowyourmeme.com" + m.group(1))
        img = re.search(r'<meta property="og:image" content="([^"]+)"', html2)
        return img.group(1) if img else None
    except Exception as e: warn(f"Know Your Meme : {e}"); return None

def download_img(url, name):
    ext = url.split("?")[0].rsplit(".",1)[-1].lower()
    if ext not in ("jpg","jpeg","png","gif","webp"): ext = "jpg"
    safe = re.sub(r"[^a-z0-9_-]","_", name.lower())[:60]
    path = os.path.join(CACHE_DIR, f"{safe}.{ext}")
    if os.path.exists(path): return path
    try:
        req = urllib.request.Request(url, headers=HEADERS)
        with urllib.request.urlopen(req, timeout=12) as r: data = r.read()
        with open(path,"wb") as f: f.write(data)
        return path
    except Exception as e: err(f"Téléchargement échoué : {e}"); return None

def find_image(query):
    db = load_db()
    r = fuzzy_local(query, db)
    if r:
        key, score = r
        src = db[key]
        warn(f"Correspondance locale : '{key}' ({int(score*100)}%)") if score < 1 else ok(f"Local : '{key}'")
        if src.startswith("http"):
            p = download_img(src, key)
            if p: return p
        elif os.path.exists(src): return src

    info("Recherche DuckDuckGo Images…")
    u = search_ddg(query)
    if u: ok("Trouvé via DuckDuckGo"); return download_img(u, query)

    info("Recherche sur Reddit…")
    u = search_reddit(query)
    if u: ok("Trouvé sur Reddit"); return download_img(u, query)

    info("Recherche sur Know Your Meme…")
    u = search_kym(query)
    if u: ok("Trouvé sur Know Your Meme"); return download_img(u, query)

    return None

