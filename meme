def ensure_pillow():
    try: from PIL import Image; return True
    except ImportError:
        info("Installation de Pillow…")
        for extra in [["--break-system-packages"], []]:
            r = subprocess.run([sys.executable,"-m","pip","install","--quiet","--user","Pillow"]+extra, capture_output=True)
            if r.returncode == 0:
                ok("Pillow installé."); return True
        return False

def open_image(path, bw=False):
    """Ouvre l'image avec Pillow, applique le fond blanc et optionnellement le NB."""
    from PIL import Image
    img = Image.open(path).convert("RGBA")
    bg  = Image.new("RGBA", img.size, (255,255,255,255))
    bg.paste(img, mask=img.split()[3])
    img = bg.convert("RGB")
    if bw:
        img = img.convert("L").convert("RGB")
    return img

def _open_default(path):
    if sys.platform == "darwin":   subprocess.run(["open", path])
    elif sys.platform == "win32":  os.startfile(path)
    else:                          subprocess.run(["xdg-open", path])

