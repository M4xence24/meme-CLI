# ── PIXEL HD ─────────────────────────────────────────────────────────────────
def _iterm2_inline(img_bytes, mime="image/png"):
    """Protocole inline images iTerm2 — envoie les bytes bruts, terminal gère la résolution."""
    b64 = base64.b64encode(img_bytes).decode()
    size = len(img_bytes)
    # ESC ] 1337 ; File=... ST
    sys.stdout.buffer.write(
        f"\033]1337;File=inline=1;size={size};width=auto;height=auto;preserveAspectRatio=1:{b64}\a\n"
        .encode()
    )
    sys.stdout.buffer.flush()

def _kitty_inline(img_bytes):
    """Protocole graphique Kitty — envoie l'image PNG en chunks base64."""
    b64 = base64.b64encode(img_bytes)
    chunk = 4096
    first = True
    for i in range(0, len(b64), chunk):
        part = b64[i:i+chunk]
        more = 1 if i + chunk < len(b64) else 0
        if first:
            header = b"\033_Ga=T,f=100,m=" + str(more).encode() + b";" + part + b"\033\\"
            first = False
        else:
            header = b"\033_Gm=" + str(more).encode() + b";" + part + b"\033\\"
        sys.stdout.buffer.write(header)
    sys.stdout.buffer.write(b"\n")
    sys.stdout.buffer.flush()

def _sixel_inline(path):
    """Envoie l'image via img2sixel (qualité maximale, supporté par xterm/mlterm/foot)."""
    cols, _ = get_term_size()
    # largeur en pixels = colonnes * ~8px (estimation)
    px_w = min(cols * 8, 1200)
    subprocess.run(["img2sixel", "-w", str(px_w), path])

def _wezterm_inline(path):
    subprocess.run(["wezterm", "imgcat", "--width", "100%", path])

def _imgcat_inline(path):
    subprocess.run(["imgcat", path])

def _viu_inline(path):
    cols, rows = get_term_size()
    subprocess.run(["viu", "-w", str(cols), "-h", str(rows-3), path])

def _chafa_inline(path, bw=False):
    cols, rows = get_term_size()
    cmd = ["chafa", f"--size={cols}x{rows-3}", "--format=symbols",
           "--color-space=din99d", "--dither=bayer", "--dither-grain=1x1"]
    if bw:
        cmd += ["--fg-only", "--palette=mono"]
    cmd.append(path)
    subprocess.run(cmd)

def detect_term_graphics():
    """Détecte les capacités graphiques du terminal courant."""
    term     = os.environ.get("TERM","")
    term_pgm = os.environ.get("TERM_PROGRAM","")
    term_var = os.environ.get("TERMINAL_EMULATOR","")
    lc_term  = os.environ.get("LC_TERMINAL","")
    colorterm= os.environ.get("COLORTERM","")

    if term == "xterm-kitty":                            return "kitty"
    if term_pgm in ("iTerm.app",) or lc_term == "iTerm2": return "iterm2"
    if "WezTerm" in term_var or term_pgm == "WezTerm":   return "wezterm"
    if shutil.which("imgcat"):                            return "iterm2"
    if shutil.which("img2sixel"):                        return "sixel"
    if shutil.which("viu"):                              return "viu"
    if shutil.which("chafa"):                            return "chafa"
    if shutil.which("timg"):                             return "timg"
    return "fallback"

def render_pixel(path, bw=False):
    """
    Mode HD : envoie l'image brute au terminal via son protocole graphique natif.
    Résolution identique à un navigateur — aucune dégradation en caractères.
    Priorité : kitty → iTerm2 → WezTerm → sixel → viu → chafa → app système.
    """
    # Préparer l'image (BW si demandé) puis re-encoder en PNG pour les protocoles
    if bw and ensure_pillow():
        from PIL import Image
        img = open_image(path, bw=True)
        import io
        buf = io.BytesIO()
        img.save(buf, format="PNG", optimize=False)
        png_bytes = buf.getvalue()
        # Écrire une version BW temporaire
        tmp = os.path.join(CACHE_DIR, "_bw_tmp.png")
        with open(tmp, "wb") as f: f.write(png_bytes)
        src_path = tmp
    else:
        # Lire les bytes bruts directement
        with open(path, "rb") as f: raw = f.read()
        # Si c'est déjà un PNG/JPG, parfait. Sinon convertir.
        if not (raw[:8] == b'\x89PNG\r\n\x1a\n' or raw[:2] == b'\xff\xd8'):
            if ensure_pillow():
                from PIL import Image
                import io
                img = Image.open(path).convert("RGB")
                buf = io.BytesIO()
                img.save(buf, format="PNG")
                with open(path.replace(path.rsplit(".",1)[-1], "png"), "wb") as f2:
                    f2.write(buf.getvalue())
        src_path = path

    cap = detect_term_graphics()

    if cap == "kitty":
        with open(src_path,"rb") as f: data = f.read()
        if not data[:8] == b'\x89PNG\r\n\x1a\n':
            if ensure_pillow():
                from PIL import Image; import io
                buf = io.BytesIO(); Image.open(src_path).convert("RGB").save(buf, "PNG")
                data = buf.getvalue()
        _kitty_inline(data)

    elif cap in ("iterm2",):
        with open(src_path,"rb") as f: data = f.read()
        _iterm2_inline(data)

    elif cap == "wezterm":
        _wezterm_inline(src_path)

    elif cap == "sixel":
        _sixel_inline(src_path)

    elif cap == "viu":
        _viu_inline(src_path)

    elif cap == "chafa":
        _chafa_inline(src_path, bw=bw)

    elif cap == "timg":
        subprocess.run(["timg", src_path])

    else:
        warn("Aucun protocole graphique détecté → ouverture avec l'app par défaut")
        _open_default(src_path)

# ── EMOJI ─────────────────────────────────────────────────────────────────────
def render_emoji(path, bw=False):
    """Blocs ██ colorés 24-bit, 2 chars de large → ratio carré."""
    if not ensure_pillow(): render_pixel(path, bw); return
    img = open_image(path, bw)
    cols, rows = get_term_size()
    max_w = min(cols // 2, 80); max_h = rows - 4
    w, h = img.size
    scale = min(max_w/w, max_h/h)
    img = img.resize((int(w*scale), int(h*scale)), __import__("PIL").Image.LANCZOS)
    px = img.load()
    lines = []
    for y in range(img.height):
        row = []
        for x in range(img.width):
            r2, g2, b2 = px[x, y]
            row.append(f"\033[38;2;{r2};{g2};{b2}m██")
        lines.append("".join(row) + "\033[0m")
    print("\n".join(lines))

# ── ASCII ─────────────────────────────────────────────────────────────────────
def render_ascii(path, bw=False):
    """Art ASCII coloré, 70 niveaux de luminosité, sharpen, luma Rec.709."""
    if not ensure_pillow(): render_pixel(path, bw); return
    from PIL import Image, ImageFilter
    CHARS = ('$@B%8&WM#*oahkbdpqwmZO0QLCJUYXzcvunxrjft/|()1{}[]?-_+~<>i!lI;:,"^`\'. ')
    img = open_image(path, bw).filter(ImageFilter.SHARPEN)
    cols, rows = get_term_size()
    max_w = min(cols, 200); max_h = (rows - 4) * 2
    w, h = img.size
    scale = min(max_w/w, max_h/(h*0.5))
    new_w = int(w*scale); new_h = max(int(h*scale*0.5), 1)
    rgb = img.resize((new_w, new_h), Image.LANCZOS)
    gray = rgb.convert("L")
    rp, gp = rgb.load(), gray.load()
    n = len(CHARS)-1
    lines = []
    for y in range(new_h):
        row = []
        for x in range(new_w):
            lum = gp[x,y]
            ch = CHARS[int(lum/255*n)]
            r2, g2, b2 = rp[x,y]
            row.append(f"\033[38;2;{r2};{g2};{b2}m{ch}")
        lines.append("".join(row)+"\033[0m")
    print("\n".join(lines))

# ── AUTO ──────────────────────────────────────────────────────────────────────
def render_auto(path, bw=False):
    """Détection automatique — même logique que pixel mais applique BW si demandé."""
    if bw and ensure_pillow():
        from PIL import Image; import io
        img = open_image(path, bw=True)
        tmp = os.path.join(CACHE_DIR, "_bw_tmp.png")
        img.save(tmp, "PNG")
        path = tmp
    cap = detect_term_graphics()
    if   cap == "kitty":   render_pixel(path)
    elif cap == "iterm2":  _imgcat_inline(path) if shutil.which("imgcat") else render_pixel(path)
    elif cap == "wezterm": _wezterm_inline(path)
    elif cap == "sixel":   _sixel_inline(path)
    elif cap == "viu":     _viu_inline(path)
    elif cap == "chafa":   _chafa_inline(path, bw=bw)
    elif shutil.which("timg"): subprocess.run(["timg", path])
    else:
        warn("Aucun renderer → ouverture avec l'app par défaut")
        _open_default(path)

